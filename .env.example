# Kick.com OAuth Configuration
# Get these from your Kick.com Developer Console
KICK_CLIENT_ID=your_kick_client_id_here
KICK_CLIENT_SECRET=your_kick_client_secret_here

# OAuth Redirect URI (should match what you set in Kick.com app settings)
REDIRECT_URI=http://localhost:3000/auth/callback

# Session Secret (generate a random string)
SESSION_SECRET=your_random_session_secret_here

# Server Port (optional, defaults to 3000)
PORT=3000

# Public app URL for Kick webhook instructions/status in the UI
# PUBLIC_BASE_URL=https://your-public-url.example

# Local-only testing switch for webhook signature verification
# KICK_SKIP_WEBHOOK_SIGNATURE=0

# Voice provider mode
# LOCAL_TTS_ENABLED=true
# LOCAL_TTS_BASE_URL=http://127.0.0.1:8000

# ElevenLabs (optional cloud fallback)
# ELEVENLABS_API_KEY=your_elevenlabs_key_here
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2