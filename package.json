{
  "name": "kick-chat-integration",
  "version": "1.0.0",
  "description": "A web app that integrates with Kick.com chat API using real-time polling",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "setup:core": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-core.ps1",
    "setup:local-tts": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-local-tts.ps1",
    "start:all": "powershell -ExecutionPolicy Bypass -File ./scripts/start-all.ps1",
    "diagnose": "powershell -ExecutionPolicy Bypass -File ./scripts/diagnose.ps1",
    "export": "powershell -ExecutionPolicy Bypass -File ./scripts/export-project.ps1"
  },
  "keywords": [
    "kick",
    "chat",
    "polling",
    "oauth"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.5.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "form-data": "^4.0.5",
    "multer": "^2.1.1",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
