<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kick.com Chat Integration</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>
    <div class="container">
        <header>
            <h1>🎮 Kick.com Chat Integration</h1>
            <div class="auth-status">
                <a href="/voices" class="btn btn-secondary">Manage Voices</a>
                <% if (isAuthenticated) { %>
                    <span class="status-badge authenticated">✅ Authenticated</span>
                    <button id="logoutBtn" class="btn btn-secondary">Logout</button>
                    <button id="debugToggleBtn" class="btn btn-secondary">🔧 Show Debug Tools</button>
                <% } else { %>
                    <span class="status-badge not-authenticated">❌ Not Authenticated</span>
                    <button id="loginBtn" class="btn btn-primary">OAuth Login with Kick.com</button>
                <% } %>
            </div>
        </header>

        <main>
            <div class="controls-section">
                <h2>Chat Controls</h2>
                
                <div class="control-group">
                    <label for="channelInput">Channel Name:</label>
                    <input type="text" id="channelInput" placeholder="Enter channel name..." 
                           value="<%= currentChannel %>" <%= !isAuthenticated ? 'disabled' : '' %>>
                </div>
                
                <div class="button-group">
                    <button id="startBtn" class="btn btn-success" <%= !isAuthenticated ? 'disabled' : '' %>>
                        Start Monitoring
                    </button>
                    <button id="stopBtn" class="btn btn-danger" <%= !isAuthenticated ? 'disabled' : '' %> style="display: none;">
                        Stop Monitoring
                    </button>
                    <button id="statusBtn" class="btn btn-info" <%= !isAuthenticated ? 'disabled' : '' %>>Check Status</button>
                </div>

                <div id="statusDisplay" class="status-display">
                    <% if (chatMonitoring) { %>
                        <span class="status-indicator monitoring">🟢 Monitoring: <%= currentChannel %></span>
                    <% } else { %>
                        <span class="status-indicator stopped">🔴 Not Monitoring</span>
                    <% } %>
                </div>
            
            <div class="debug-buttons" style="display: none;">
                <h3>🐛 Debug & Development Tools</h3>
                <div class="button-group">
                    <button id="debugTokenBtn" class="btn btn-info" <%= !isAuthenticated ? 'disabled' : '' %>>
                        🔍 Check Token Status
                    </button>
                    <button id="getLiveChat" class="btn btn-success" <%= !isAuthenticated ? 'disabled' : '' %>>
                        💬 Manual Chat Fetch
                    </button>
                </div>
            </div>

            <div class="tts-controls">
                <h3>🔊 Text-to-Speech Controls</h3>
                <div class="control-group">
                    <label>
                        <input type="checkbox" id="ttsEnabled" checked> Enable Text-to-Speech
                    </label>
                    <label>
                        <input type="checkbox" id="ttsMuted"> Mute Immediately
                    </label>
                    <label>
                        TTS Speed: <input type="range" id="ttsSpeed" min="0.5" max="2" step="0.1" value="1">
                        <span id="speedValue">1.0</span>
                    </label>
                    <label>
                        Volume: <input type="range" id="ttsVolume" min="0" max="100" step="1" value="80">
                        <span id="volumeValue">80%</span>
                    </label>
                </div>
                <div class="tts-mode-grid">
                    <label for="ttsModeSelect">
                        Playback Mode:
                        <select id="ttsModeSelect">
                            <option value="autoplay" selected>Autoplay</option>
                            <option value="manual">Manual</option>
                            <option value="hybrid">Hybrid</option>
                        </select>
                    </label>
                    <label>
                        Autoplay Speed:
                        <input type="range" id="ttsSpeedAutoplay" min="0.5" max="2" step="0.1" value="1.0">
                        <span id="speedValueAutoplay">1.0x</span>
                    </label>
                    <label>
                        Manual Speed:
                        <input type="range" id="ttsSpeedManual" min="0.5" max="2" step="0.1" value="1.0">
                        <span id="speedValueManual">1.0x</span>
                    </label>
                    <label>
                        Hybrid Speed:
                        <input type="range" id="ttsSpeedHybrid" min="0.5" max="2" step="0.1" value="1.0">
                        <span id="speedValueHybrid">1.0x</span>
                    </label>
                </div>
                <div class="tts-mode-grid">
                    <label for="ttsTriggerModeSelect">
                        Trigger Mode:
                        <select id="ttsTriggerModeSelect" <%= !isAuthenticated ? 'disabled' : '' %>>
                            <option value="chat_commands" selected>Chat Commands Only</option>
                            <option value="channel_points">Channel Points Only</option>
                            <option value="both">Chat Commands + Channel Points</option>
                        </select>
                    </label>
                    <label for="channelPointsRewardTitleInput">
                        Channel Point Reward Title:
                        <input type="text" id="channelPointsRewardTitleInput" value="Test-tts" placeholder="Test-tts" <%= !isAuthenticated ? 'disabled' : '' %>>
                    </label>
                </div>
                <div class="button-group tts-playback-actions">
                    <button id="saveTtsTriggerSettingsBtn" class="btn btn-secondary" type="button" <%= !isAuthenticated ? 'disabled' : '' %>>Save Trigger Settings</button>
                    <button id="subscribeChannelPointsBtn" class="btn btn-success" type="button" <%= !isAuthenticated ? 'disabled' : '' %> style="display: none;">Subscribe To Reward Redemptions</button>
                </div>
                <div class="button-group tts-playback-actions">
                    <button id="playNextManualBtn" class="btn btn-primary" type="button">Play Next Manual</button>
                    <button id="skipCurrentBtn" class="btn btn-warning" type="button">Skip Current</button>
                    <button id="clearQueueBtn" class="btn btn-secondary" type="button">Clear Queue</button>
                    <button id="replayLastBtn" class="btn btn-info" type="button" style="display: none;">Replay Last</button>
                </div>
                <p id="ttsModeDescription" class="tts-mode-description">Autoplay mode reads all eligible new messages automatically.</p>
                <p id="ttsTriggerModeDescription" class="tts-mode-description">Chat commands are currently the only accepted trigger.</p>
                <p id="channelPointsStatus" class="tts-mode-description" style="display: none;">Reward redemptions are not subscribed yet.</p>
            </div>

            <div class="moderation-controls">
                <h3>🛡️ Moderation & Permissions</h3>
                
                <div class="control-group">
                    <label>
                        <input type="checkbox" id="enableBanList" checked> Enable Ban List
                    </label>
                    <label>
                        <input type="checkbox" id="enablePermissionFilter"> Enable Permission Filter
                    </label>
                </div>
                
                <div class="control-group">
                    <label for="permissionModeSelect">
                        Permission Mode:
                        <select id="permissionModeSelect">
                            <option value="all" selected>All Users</option>
                            <option value="subscribers_only">Subscribers Only</option>
                            <option value="moderators_only">Moderators Only</option>
                            <option value="vips_only">VIPs Only</option>
                        </select>
                    </label>
                </div>
                
                <div class="ban-list-management">
                    <h4>Ban List Management</h4>
                    <div class="control-group">
                        <input type="text" id="banUsernameInput" placeholder="Username to ban..." <%= !isAuthenticated ? 'disabled' : '' %>>
                        <button id="addBanBtn" class="btn btn-danger" <%= !isAuthenticated ? 'disabled' : '' %>>Ban User</button>
                    </div>
                    <div id="banList" class="ban-list">
                        <p class="ban-list-empty">No banned users</p>
                    </div>
                </div>
                
                <div class="button-group">
                    <button id="saveModerationSettingsBtn" class="btn btn-secondary" <%= !isAuthenticated ? 'disabled' : '' %>>Save Moderation Settings</button>
                    <button id="loadModerationSettingsBtn" class="btn btn-info" <%= !isAuthenticated ? 'disabled' : '' %>>Load Settings</button>
                </div>
            </div>

            <div class="chat-section">
                <h2>💬 Live Chat Messages</h2>
                <div class="chat-stats">
                    <span id="messageCount">Messages: 0</span>
                    <span id="ttsCount">TTS Spoken: 0</span>
                    <span id="replayCount" style="display: none;">Manual Replays: 0</span>
                    <span id="manualQueueCount">Manual Queue: 0</span>
                    <span id="currentModeStat">Mode: autoplay</span>
                    <span id="currentTriggerModeStat">Trigger: chat_commands</span>
                    <span id="lastUpdate">Last Update: Never</span>
                </div>
                <div id="liveChatMessages" class="chat-container">
                    <div class="no-messages">💬 Live chat messages will appear here...</div>
                </div>
            </div>
        </main>

        <footer>
            <div class="app-info">
                <h3>Real-time Chat Integration via API Polling</h3>
                <p>This app uses direct API polling to fetch chat messages in real-time.</p>
            </div>
        </footer>
    </div>

    <script src="/js/main.js"></script>
</body>
</html>